MONGO_URI=mongodb://127.0.0.1:27017/dynamiqr
PORT=5000
NODE_ENV=development
SESSION_SECRET=your-secret-key
JWT_SECRET=your-jwt-secret

# URLs (נדרש ל-OAuth וללוגו במייל בפרודקשן)
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5000

# שליחת מייל (Gmail App Password — https://myaccount.google.com/apppasswords)
SMTP_SERVICE=gmail
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="דינמיקר" <your-email@gmail.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=0

# OAuth - גוגל (מ-https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# OAuth - פייסבוק (מ-https://developers.facebook.com)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# אופציונלי — פיתוח
# RATE_LIMIT_DISABLED=1
# MONGODB_SERVER_API=1
